{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/skills/worktree-review-gate/scripts/gate.sh\" SessionStart",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/skills/worktree-review-gate/scripts/gate.sh\" Stop",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

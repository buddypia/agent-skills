# Copy to config.yaml or config.json and edit values as needed.
# YAML format example.

global:
  # shuffle(default/random by default) | random(duplicates allowed) | fixed(pinned)
  provider_strategy: shuffle
  temperature: 0.7

proponent:
  provider: gemini
  model: gemini-3.5-flash
  api_key: YOUR_GEMINI_API_KEY
  temperature: 0.7

opponent:
  provider: anthropic
  model: claude-opus-4-8
  api_key: YOUR_ANTHROPIC_API_KEY
  temperature: 0.7

moderator:
  provider: openai
  model: gpt-5.5
  api_key: YOUR_OPENAI_API_KEY
  base_url: https://api.openai.com/v1
  temperature: 0.7

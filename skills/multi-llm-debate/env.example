# Copy to .env ONLY if needed — normally not required.
# Authentication defaults to the subscription login of each CLI (agy / claude / codex), so .env and API keys are usually unnecessary.
# The keys below are a fallback for cases such as "sandbox runs where the CLI cannot log in" (leaving them empty is fine).

# Provider API keys (optional — not required if the CLI is already logged in)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: OpenAI base URL (e.g., for compatible endpoints)
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL_ID=
ANTHROPIC_MODEL_ID=
OPENAI_CHAT_MODEL_ID=

# Provider assignment strategy (shuffle[default/random by default] | random | fixed)
DEBATE_PROVIDER_STRATEGY=shuffle
# DEBATE_PROVIDER_MODE=
# DEBATE_RANDOM_PROVIDERS=false
# DEBATE_SHUFFLE_PROVIDERS=false

# Role-specific overrides
DEBATE_PROPONENT_PROVIDER=
DEBATE_PROPONENT_MODEL=
DEBATE_PROPONENT_API_KEY=
DEBATE_PROPONENT_BASE_URL=
DEBATE_PROPONENT_TEMPERATURE=

DEBATE_OPPONENT_PROVIDER=
DEBATE_OPPONENT_MODEL=
DEBATE_OPPONENT_API_KEY=
DEBATE_OPPONENT_BASE_URL=
DEBATE_OPPONENT_TEMPERATURE=

DEBATE_MODERATOR_PROVIDER=
DEBATE_MODERATOR_MODEL=
DEBATE_MODERATOR_API_KEY=
DEBATE_MODERATOR_BASE_URL=
DEBATE_MODERATOR_TEMPERATURE=

# Global temperature override
DEBATE_TEMPERATURE=
LLM_TEMPERATURE=

# Optional: config file path
CONFIG_FILE=

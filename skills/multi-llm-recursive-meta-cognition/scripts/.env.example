# ===========================================
# Multi-LLM Reflection Pattern Configuration (5 stages)
# Reflection-pattern multi-agent settings
# ===========================================
#
# Configuration priority (highest first):
#   1. CLI arguments (--decomposer-model, etc.)
#   2. Environment variables (this file)
#   3. Configuration file (config.yaml)
#   4. Default values
#
# ===========================================

# ===========================================
# API keys (required)
# ===========================================

# Gemini API (Decomposer / Solver)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API (Verifier)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (Integrator / Reflector)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # When using Azure OpenAI, etc.

# ===========================================
# Provider-specific model IDs (optional)
# ===========================================

# GEMINI_MODEL_ID=gemini-3.5-flash
# ANTHROPIC_MODEL_ID=claude-opus-4-1-20250805
# OPENAI_CHAT_MODEL_ID=gpt-5.2

# ===========================================
# Per-agent settings (optional)
# Format: REFLECTION_<ROLE>_<KEY>
# ===========================================

# [Decomposer]
# REFLECTION_DECOMPOSER_PROVIDER=gemini
# REFLECTION_DECOMPOSER_MODEL=gemini-3.5-flash
# REFLECTION_DECOMPOSER_API_KEY=your_key_here  # Takes priority over GEMINI_API_KEY
# REFLECTION_DECOMPOSER_TEMPERATURE=0.7
# REFLECTION_DECOMPOSER_TIMEOUT=120

# [Solver]
# REFLECTION_SOLVER_PROVIDER=gemini
# REFLECTION_SOLVER_MODEL=gemini-3.5-flash
# REFLECTION_SOLVER_API_KEY=your_key_here  # Takes priority over GEMINI_API_KEY
# REFLECTION_SOLVER_TEMPERATURE=0.7
# REFLECTION_SOLVER_TIMEOUT=120

# [Verifier]
# REFLECTION_VERIFIER_PROVIDER=anthropic
# REFLECTION_VERIFIER_MODEL=claude-opus-4-1-20250805
# REFLECTION_VERIFIER_API_KEY=your_key_here  # Takes priority over ANTHROPIC_API_KEY
# REFLECTION_VERIFIER_TEMPERATURE=0.7
# REFLECTION_VERIFIER_TIMEOUT=120

# [Integrator]
# REFLECTION_INTEGRATOR_PROVIDER=openai
# REFLECTION_INTEGRATOR_MODEL=gpt-5.2
# REFLECTION_INTEGRATOR_API_KEY=your_key_here  # Takes priority over OPENAI_API_KEY
# REFLECTION_INTEGRATOR_BASE_URL=https://api.openai.com/v1
# REFLECTION_INTEGRATOR_TEMPERATURE=0.7
# REFLECTION_INTEGRATOR_TIMEOUT=120

# [Reflector]
# REFLECTION_REFLECTOR_PROVIDER=openai
# REFLECTION_REFLECTOR_MODEL=gpt-5.2
# REFLECTION_REFLECTOR_API_KEY=your_key_here  # Takes priority over OPENAI_API_KEY
# REFLECTION_REFLECTOR_BASE_URL=https://api.openai.com/v1
# REFLECTION_REFLECTOR_TEMPERATURE=0.7
# REFLECTION_REFLECTOR_TIMEOUT=120

# ===========================================
# Common parameters (optional)
# ===========================================

# Temperature for all agents (default: 0.7)
# REFLECTION_TEMPERATURE=0.7
# LLM_TEMPERATURE=0.7  # Backward compatible

# Timeout in seconds per agent (default: 120)
# REFLECTION_TIMEOUT=120
# LLM_TIMEOUT_SEC=120  # Backward compatible

# ===========================================
# DevUI settings
# ===========================================

# Port number for the DevUI server (default: 8095)
# REFLECTION_DEVUI_PORT=8095
# DEVUI_PORT=8095  # Backward compatible

# ===========================================
# Configuration file path (optional)
# ===========================================

# Specify when using a YAML/JSON configuration file
# CONFIG_FILE=config.yaml

# ===========================================
# Default values
# ===========================================
# Decomposer: gemini / gemini-3.5-flash
# Solver:    gemini / gemini-3.5-flash
# Verifier:  anthropic / claude-opus-4-1-20250805
# Integrator: openai / gpt-5.2
# Reflector:  openai / gpt-5.2
#
# View configuration details: python main.py --show-config

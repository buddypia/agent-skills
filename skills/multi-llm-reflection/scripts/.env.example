# ===========================================
# Multi-LLM Reflection Pattern Configuration
# Reflection pattern multi-agent configuration
# ===========================================
#
# Configuration priority (highest first):
#   1. CLI arguments (--generator-model, etc.)
#   2. Environment variables (this file)
#   3. Config file (config.yaml)
#   4. Default values
#
# ===========================================

# ===========================================
# API keys (required)
# ===========================================

# Gemini API (Generator - creates the initial draft)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API (Critic - critique and improvement suggestions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (Refiner - creates the final version)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # When using Azure OpenAI, etc.

# ===========================================
# Provider-specific model IDs (optional)
# ===========================================

# Default model for each provider
# GEMINI_MODEL_ID=gemini-3.5-flash
# ANTHROPIC_MODEL_ID=claude-opus-4-1-20250805
# OPENAI_CHAT_MODEL_ID=gpt-5.2

# ===========================================
# Per-agent configuration (optional)
# REFLECTION_<ROLE>_<KEY> format
# ===========================================

# [Generator (creates the initial draft)]
# REFLECTION_GENERATOR_PROVIDER=gemini
# REFLECTION_GENERATOR_MODEL=gemini-3.5-flash
# REFLECTION_GENERATOR_API_KEY=your_key_here  # Takes precedence over GEMINI_API_KEY
# REFLECTION_GENERATOR_TEMPERATURE=0.7
# REFLECTION_GENERATOR_TIMEOUT=120

# [Critic (critique and improvement suggestions)]
# REFLECTION_CRITIC_PROVIDER=anthropic
# REFLECTION_CRITIC_MODEL=claude-opus-4-1-20250805
# REFLECTION_CRITIC_API_KEY=your_key_here  # Takes precedence over ANTHROPIC_API_KEY
# REFLECTION_CRITIC_TEMPERATURE=0.7
# REFLECTION_CRITIC_TIMEOUT=120

# [Refiner (creates the final version)]
# REFLECTION_REFINER_PROVIDER=openai
# REFLECTION_REFINER_MODEL=gpt-5.2
# REFLECTION_REFINER_API_KEY=your_key_here  # Takes precedence over OPENAI_API_KEY
# REFLECTION_REFINER_BASE_URL=https://api.openai.com/v1
# REFLECTION_REFINER_TEMPERATURE=0.7
# REFLECTION_REFINER_TIMEOUT=120

# ===========================================
# Common parameters (optional)
# ===========================================

# Temperature for all agents (default: 0.7)
# REFLECTION_TEMPERATURE=0.7
# LLM_TEMPERATURE=0.7  # Backward compatible

# Performance / wall-clock budget — these MULTILLM_* knobs are the ones ACTUALLY honored:
# MULTILLM_REASONING_EFFORT=high   # Claude --effort + Codex reasoning (medium = faster, xhigh = slowest)
# MULTILLM_CLI_TIMEOUT=360         # per-CLI-call timeout (seconds)
# MULTILLM_TOTAL_DEADLINE=540      # whole-run wall-clock budget; keeps the run under a ~600s agent/Bash ceiling
#
# NOTE: the legacy REFLECTION_*_TIMEOUT / REFLECTION_TIMEOUT / LLM_TIMEOUT_SEC vars below are NOT
# read by this skill — the per-stage timeout is governed by the MULTILLM_* knobs above. Kept only
# for documentation; use the MULTILLM_* variables instead.
# REFLECTION_TIMEOUT=120
# LLM_TIMEOUT_SEC=120  # Backward compatible

# ===========================================
# DevUI configuration
# ===========================================

# Port number for the DevUI server (default: 8095)
# REFLECTION_DEVUI_PORT=8095
# DEVUI_PORT=8095  # Backward compatible

# ===========================================
# Config file path (optional)
# ===========================================

# Specify this when using a YAML/JSON config file
# CONFIG_FILE=config.yaml

# ===========================================
# Default values
# ===========================================
# Generator: gemini / gemini-3.5-flash
# Critic:    anthropic / claude-opus-4-1-20250805
# Refiner:   openai / gpt-5.2
#
# Show configuration details: python main.py --show-config
